{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "src/core/**/*",
    "src/heart/**/*",
    "src/sensorium/**/*",
    "src/mcp/**/*",
    "src/experiment/signals.ts",
    "src/supply-chain/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}

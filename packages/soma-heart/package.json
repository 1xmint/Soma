{
  "name": "soma-heart",
  "version": "0.3.0",
  "description": "The heart of agent identity — execution runtime with per-token HMAC, birth certificates, credential rotation, human-consent session mode, and cryptographic heartbeat chain",
  "type": "module",
  "main": "./dist/heart/index.js",
  "types": "./dist/heart/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/heart/index.d.ts",
      "import": "./dist/heart/index.js",
      "default": "./dist/heart/index.js"
    },
    "./core": {
      "types": "./dist/core/genome.d.ts",
      "import": "./dist/core/genome.js",
      "default": "./dist/core/genome.js"
    },
    "./credential-rotation": {
      "types": "./dist/heart/credential-rotation/index.d.ts",
      "import": "./dist/heart/credential-rotation/index.js",
      "default": "./dist/heart/credential-rotation/index.js"
    },
    "./crypto-provider": {
      "types": "./dist/core/crypto-provider.d.ts",
      "import": "./dist/core/crypto-provider.js",
      "default": "./dist/core/crypto-provider.js"
    },
    "./sense": {
      "types": "./dist/sensorium/index.d.ts",
      "import": "./dist/sensorium/index.js",
      "default": "./dist/sensorium/index.js"
    },
    "./senses": {
      "types": "./dist/sensorium/senses/index.d.ts",
      "import": "./dist/sensorium/senses/index.js",
      "default": "./dist/sensorium/senses/index.js"
    },
    "./atlas": {
      "types": "./dist/sensorium/atlas.d.ts",
      "import": "./dist/sensorium/atlas.js",
      "default": "./dist/sensorium/atlas.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    },
    "./signals": {
      "types": "./dist/experiment/signals.d.ts",
      "import": "./dist/experiment/signals.js",
      "default": "./dist/experiment/signals.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "agent-identity",
    "mcp",
    "model-context-protocol",
    "hmac",
    "cryptography",
    "data-provenance",
    "birth-certificate",
    "heartbeat",
    "credential-rotation",
    "temporal-fingerprint",
    "sensorium",
    "phenotype",
    "behavioral-analysis",
    "soma"
  ],
  "author": "Joshua Fair",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1xmint/Soma"
  },
  "homepage": "https://github.com/1xmint/Soma",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "openai": ">=4.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
}

{
  "name": "soma-heart",
  "version": "0.1.1",
  "description": "The heart of agent identity — execution runtime with per-token HMAC, birth certificates, and cryptographic heartbeat chain",
  "type": "module",
  "main": "./dist/heart/index.js",
  "types": "./dist/heart/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/heart/index.d.ts",
      "import": "./dist/heart/index.js",
      "default": "./dist/heart/index.js"
    },
    "./core": {
      "types": "./dist/core/genome.d.ts",
      "import": "./dist/core/genome.js",
      "default": "./dist/core/genome.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "agent-identity",
    "mcp",
    "model-context-protocol",
    "hmac",
    "cryptography",
    "data-provenance",
    "birth-certificate",
    "heartbeat",
    "soma"
  ],
  "author": "Joshua Fair",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1xmint/Soma"
  },
  "homepage": "https://github.com/1xmint/Soma",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openai": ">=4.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
}

{
  "name": "soma",
  "version": "0.1.0",
  "description": "Agent identity verification through computational phenotyping",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "experiment": "tsx src/experiment/runner.ts",
    "experiment:anthropic": "tsx src/experiment/runner.ts --provider=anthropic",
    "experiment:openai": "tsx src/experiment/runner.ts --provider=openai",
    "experiment:groq": "tsx src/experiment/runner.ts --provider=groq",
    "experiment:mistral": "tsx src/experiment/runner.ts --provider=mistral",
    "experiment:openrouter": "tsx src/experiment/runner.ts --provider=openrouter",
    "analyze": "tsx src/experiment/analyze.ts",
    "analyze:full": "tsx src/experiment/merge-and-analyze.ts",
    "analyze:optimize": "tsx src/experiment/optimize-sensorium.ts",
    "generate-synthetic": "tsx src/experiment/generate-synthetic.ts",
    "experiment:agents": "tsx src/experiment/agents/run-agent-experiment.ts",
    "test:heart-live": "tsx src/experiment/heart-live-test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}

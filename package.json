{
  "name": "soma",
  "version": "0.1.0",
  "description": "Agent identity verification through computational phenotyping",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "build:packages": "node scripts/build-packages.mjs",
    "pack:heart": "npm pack ./packages/soma-heart",
    "test": "vitest run",
    "test:watch": "vitest",
    "experiment": "tsx src/experiment/runner.ts",
    "experiment:anthropic": "tsx src/experiment/runner.ts --provider=anthropic",
    "experiment:openai": "tsx src/experiment/runner.ts --provider=openai",
    "experiment:groq": "tsx src/experiment/runner.ts --provider=groq",
    "experiment:mistral": "tsx src/experiment/runner.ts --provider=mistral",
    "experiment:openrouter": "tsx src/experiment/runner.ts --provider=openrouter",
    "analyze": "tsx src/experiment/analyze.ts",
    "analyze:full": "tsx src/experiment/merge-and-analyze.ts",
    "analyze:optimize": "tsx src/experiment/optimize-sensorium.ts",
    "benchmark:hmac": "tsx src/experiment/benchmark-hmac.ts",
    "bench": "tsx bench/index.ts",
    "generate-synthetic": "tsx src/experiment/generate-synthetic.ts",
    "experiment:agents": "tsx src/experiment/agents/run-agent-experiment.ts",
    "test:heart-live": "tsx src/experiment/heart-live-test.ts",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build:packages",
    "install:hooks": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "node packages/secret-scanner/bin/pre-commit.js"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "simple-git-hooks": "^2.11.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.12",
      "@hono/node-server": "1.19.13",
      "path-to-regexp": "8.4.0",
      "vite": "8.0.5"
    }
  }
}
